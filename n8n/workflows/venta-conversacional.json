              {
                "name": "rut",
                "value": "={{ $json.rut }}"
              },
              {
                "name": "items",
                "value": "={{ $json.items || [] }}"
              },
              {
                "name": "total",
                "value": "={{ $json.total || 0 }}"
              },
              {
                "name": "customer",
                "value": "={{ $json.customer || {} }}"
              }
            ]
          },
          "options": {}
        },
        "id": "create-order",
        "name": "HTTP: Order Engine",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4,
        "position": [1050, 200]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "http://localhost:3080/payments/flow/create",
          "sendBody": true,
          "bodyParameters": {
            "parameters": [
              {
                "name": "order_id",
                "value": "={{ $json.data.order_id }}"
              },
              {
                "name": "amount",
                "value": "={{ $json.data.total }}"
              },
              {
                "name": "email",
                "value": "={{ $json.customer.email || 'cliente@email.com' }}"
              },
              {
                "name": "subject",
                "value": "Pago orden {{ $json.data.order_id }}"
              }
            ]
          },
          "options": {}
        },
        "id": "create-payment",
        "name": "HTTP: Payment Engine",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4,
        "position": [1250, 200]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "={{ $json.chat_webhook_url || 'https://api.telegram.org/botYOUR_BOT/sendMessage' }}",
