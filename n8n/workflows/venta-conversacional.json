          "bodyParameters": {
            "parameters": [
              {
                "name": "chat_id",
                "value": "={{ $json.chat_id || '123456789' }}"
              },
              {
                "name": "text",
                "value": "✅ Orden creada: {{ $json.data.order_id }}\n\nMonto: ${{ $json.data.total.toLocaleString() }}\n\nLink de pago: {{ $json.data.payment_url }}\n\n¡Gracias por tu compra!"
              }
            ]
          },
          "options": {}
        },
        "id": "send-payment-link",
        "name": "Send Payment Link",
