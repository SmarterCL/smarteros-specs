        },
        "id": "webhook-chat",
        "name": "Webhook (Chat)",
        "type": "n8n-nodes-base.webhook",
        "typeVersion": 2,
        "position": [250, 300]
      },
      {
        "parameters": {
          "jsCode": "// Limpiar RUT del input\nconst rut = $input.first().json.rut || $input.first().json.body?.rut;\n\nfunction cleanRut(rut) {\n  if (!rut) return null;\n  return rut.toString()\n    .replace(/\\./g, '')\n    .replace(/-/g, '')\n    .replace(/\\s/g, '')\n    .toUpperCase();\n}\n\nreturn [{\n  json: {\n    rut: cleanRut(rut),\n    original_rut: rut\n  }\n}];"
        },
        "id": "clean-rut",
        "name": "Function: Limpiar RUT",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [450, 300]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "http://localhost:3080/identity/rut/validate",
          "sendBody": true,
          "bodyParameters": {
            "parameters": [
              {
                "name": "rut",
                "value": "={{ $json.rut }}"
              }
            ]
          },
          "options": {}
        },
        "id": "validate-rut",
        "name": "HTTP: Identity Engine",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4,
        "position": [650, 300]
      },
      {
        "parameters": {
          "conditions": {
            "boolean": [
              {
                "value1": "={{ $json.valid }}",
                "value2": true
              }
            ]
          }
        },
        "id": "check-rut-valid",
        "name": "IF: RUT Válido",
        "type": "n8n-nodes-base.if",
        "typeVersion": 1,
        "position": [850, 300]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "http://localhost:3080/orders/create",
          "sendBody": true,
          "bodyParameters": {
